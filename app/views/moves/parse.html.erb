<div class="page-header">
  <span class="page-header-title">Text to Move</span>
</div>

<div class="page-content">
  <div class="wizard-stage" style="min-height: auto; padding: 0;">
    <div class="wizard-card" style="max-width: 600px;">
      <div class="wizard-heading">
        <h1 class="wizard-question">Paste your text</h1>
        <p class="wizard-hint">
          Dictate with WisprFlow, voice memos, or just paste any text.
          We'll extract the structured fields for you.
        </p>
      </div>

      <%= form_with url: parse_moves_path, method: :post, data: { turbo: false } do |f| %>
        <textarea name="raw_text" class="wizard-textarea" rows="8"
                  placeholder="<%= @placeholder_text %>"
                  autofocus
                  style="min-height: 160px; resize: vertical;"></textarea>

        <div class="parse-template-hint">
          <div class="parse-template-label">What to talk about:</div>
          <ul class="parse-template-list">
            <li>What's the move? (the action you want to take)</li>
            <li>Who's involved? What's the context?</li>
            <li>What would success look like?</li>
            <li>How much is it worth? ($ or relative)</li>
            <li>How likely is it? How much effort?</li>
            <li>Any deadline?</li>
          </ul>
        </div>

        <div class="wizard-footer" style="justify-content: flex-end;">
          <%= link_to "Cancel", inbox_path, class: "wizard-skip", style: "margin-right: auto;" %>
          <button type="submit" class="btn btn-primary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
            Parse with AI
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
