<div class="page-header">
  <a href="javascript:history.back()" class="btn btn-ghost btn-sm wizard-back-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back
  </a>
  <span class="page-header-title" style="font-size:14px; font-weight:500;">New campaign</span>
  <%= link_to "Cancel", campaigns_path, class: "btn btn-ghost btn-sm" %>
</div>

<div class="page-content" style="max-width: 600px; margin: 0 auto;">
  <%= form_with model: @campaign, data: { turbo: false } do |f| %>
    <% if @campaign.errors.any? %>
      <div class="flash flash-alert" style="margin-bottom:16px;">
        <strong>Fix these fields:</strong>
        <ul><% @campaign.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :name %>
      <%= f.text_field :name, required: true, placeholder: "Quick Pay Rollout", autofocus: true %>
    </div>

    <div class="field">
      <%= f.label :objective, "Objective" %>
      <%= f.text_area :objective, placeholder: "What are we trying to achieve with this campaign?", rows: 3 %>
    </div>

    <div class="field">
      <%= f.label :project_id, "Project" %>
      <%= f.select :project_id,
          Project.order(:name).map { |p| [p.name, p.id] },
          { include_blank: "No project" }, {} %>
    </div>

    <div class="form-actions">
      <%= f.submit "Create campaign", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
