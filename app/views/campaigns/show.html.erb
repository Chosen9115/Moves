<% momentum = @campaign.momentum_score || 0 %>
<% momentum_badge, momentum_class = if momentum > 0.3
    ["Rising", "badge-green"]
  elsif momentum < -0.3
    ["Stalled", "badge-amber"]
  else
    ["Steady", "badge-blue"]
  end %>
<% ev_label = if @campaign.total_ev.present?
    @campaign.total_ev >= 8 ? "High" : @campaign.total_ev >= 4 ? "Med" : "Low"
  else
    nil
  end %>
<% pipeline_total = @moves.sum { |m| m.payoff_value_raw.to_f } %>

<div class="page-header">
  <div style="display:flex; align-items:center; gap:8px;">
    <%= link_to campaigns_path, style: "display:flex; align-items:center; gap:4px; color:var(--muted); font-size:13px;" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Campaigns
    <% end %>
  </div>
  <div class="page-header-right">
    <%= link_to "Edit", edit_campaign_path(@campaign), class: "btn btn-ghost" %>
    <%= button_to "Delete", campaign_path(@campaign), method: :delete, class: "btn btn-ghost", style: "color:var(--amber);", form: { data: { turbo_confirm: "Delete this campaign?" }, style: "display:inline;" } %>
  </div>
</div>

<div class="page-content">

  <%# ── Campaign briefing ─────────────────────────────────── %>
  <div style="margin-bottom:28px;">
    <div style="display:flex; align-items:center; gap:8px;">
      <% if @campaign.project.present? %>
        <span class="project-dot" style="background:<%= @campaign.project.color %>;"></span>
      <% end %>
      <h1 class="detail-title"><%= @campaign.name %></h1>
    </div>
    <% if @campaign.objective.present? %>
      <p style="margin:8px 0 0; color:var(--muted); font-size:14px; line-height:1.5;"><%= @campaign.objective %></p>
    <% end %>
  </div>

  <%# ── Stats row ─────────────────────────────────────────── %>
  <div class="campaign-stats" style="margin-bottom:28px;">
    <div>
      <div class="campaign-stat-val"><%= @campaign.active_move_count %></div>
      <div class="campaign-stat-label">active <%= "move".pluralize(@campaign.active_move_count) %></div>
    </div>
    <% if pipeline_total > 0 %>
      <div>
        <div class="campaign-stat-val accent">$<%= number_with_delimiter(pipeline_total.to_i) %></div>
        <div class="campaign-stat-label">pipeline value</div>
      </div>
    <% end %>
    <% if ev_label %>
      <div>
        <div class="campaign-stat-val <%= ev_label == 'High' ? 'accent' : ev_label == 'Low' ? 'muted' : '' %>"><%= ev_label %></div>
        <div class="campaign-stat-label">aggregate EV</div>
      </div>
    <% end %>
    <div>
      <div class="campaign-stat-val"><span class="badge <%= momentum_class %>" style="font-size:11px;"><%= momentum_badge %></span></div>
      <div class="campaign-stat-label">momentum</div>
    </div>
  </div>

  <%# ── Top move callout ──────────────────────────────────── %>
  <% if @top_move %>
    <div style="margin-bottom:28px; padding:12px 16px; background:var(--accent-soft); border-radius:8px; font-size:14px;">
      <span style="color:var(--accent); font-weight:500;">Best move</span>
      <span style="color:var(--muted); margin:0 6px;">&rarr;</span>
      <%= link_to @top_move.title, move_path(@top_move), style: "color:var(--ink); font-weight:500;" %>
    </div>
  <% end %>

  <%# ── Moves list ────────────────────────────────────────── %>
  <div class="section-gap">
    <div class="section-label">
      Moves in this campaign
      <span class="section-label-count"><%= @moves.size %></span>
    </div>
    <% if @moves.any? %>
      <div class="move-list">
        <% @moves.each do |move| %>
          <%= render "moves/move_row", move: move, top_ranked: false %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <p style="margin:0 0 4px; font-weight:500; color:var(--ink);">No moves yet.</p>
        <p style="margin:0; color:var(--muted);">
          <%= link_to "Add a move", new_move_path(campaign_id: @campaign.id), style: "color:var(--accent);" %>
          to start building this campaign.
        </p>
      </div>
    <% end %>
  </div>

</div>
